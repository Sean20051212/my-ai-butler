# ── LLM provider ─────────────────────────────────────────────────────────────
# Which LLM backend to use. Options:
#   ollama  — local inference via Ollama (default)
#   cloud   — hosted API (NOT YET IMPLEMENTED; raises NotImplementedError)
LLM_PROVIDER=ollama

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:7b
VISION_MODEL=llava

# ── TTS (cloud voice cloning) ────────────────────────────────────────────────
# Which TTS backend to use. Currently only the "cloud" skeleton exists; it is
# not implemented yet, so synthesis returns None (chat works, just no audio).
TTS_PROVIDER=cloud
#
# Vendor not decided yet. When chosen, uncomment the relevant key below.
# (DISABLED — not read by any code until the provider is implemented.)
# ELEVENLABS_API_KEY=
# AZURE_SPEECH_KEY=
# PLAYHT_API_KEY=

# ── Audio cache ──────────────────────────────────────────────────────────────
# Generated audio is cached here; same text always hits cache on second request.
AUDIO_CACHE_DIR=./cache/audio

# ── Obsidian memory (optional) ───────────────────────────────────────────────
# Leave blank to disable long-term memory entirely.
# When set, the vault is indexed into ChromaDB and relevant notes are injected
# into every system prompt.  Replies are also written back to the vault under
# AI-Butler-Memory/YYYY-MM-DD.md.
# Requires: pip install chromadb  AND  ollama pull nomic-embed-text
OBSIDIAN_VAULT_PATH=
EMBED_MODEL=nomic-embed-text
CHROMA_DB_PATH=./data/chroma
